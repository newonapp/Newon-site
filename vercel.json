{
  "rewrites": [
    { "source": "/terms", "destination": "/terms/" },
    { "source": "/privacy", "destination": "/privacy/" }
  ],
  "trailingSlash": true,
  "headers": [
    {
      "source": "/app-ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ]
}
