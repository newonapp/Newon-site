{
  "name": "newon-site",
  "private": true,
  "scripts": {
    "validate:sp": "node scripts/validate-sp-locales.mjs",
    "validate:locales": "node scripts/check-locales.mjs",
    "translate:locales": "node scripts/run-all-locale-patches.mjs --translate",
    "sync:locales-en": "node scripts/sync-locale-fallback-from-en.mjs",
    "merge:sp": "node scripts/merge-subping-locales.mjs",
    "올리기": "bash -c 'git add -A && (git diff --cached --quiet || git commit -m \"Site update\") && git push origin main'",
    "push": "bash scripts/push-to-github.sh",
    "upload": "bash scripts/push-to-github.sh",
    "export:icons": "node scripts/export-app-icons.mjs",
    "export:promo": "python3 scripts/export-promo-assets.py",
    "preview": "node scripts/publish-site.mjs && python3 -m http.server 8765 --directory _publish",
    "미리보기": "node scripts/quick-preview.mjs",
    "browse": "node scripts/quick-preview.mjs",
    "serve": "node scripts/publish-site.mjs && node scripts/serve-publish.mjs",
    "open:preview": "node scripts/open-simple-browser.mjs",
    "open:cursor": "node scripts/open-simple-browser.mjs",
    "open:newon": "node scripts/open-simple-browser.mjs \"https://newon.app/ko/\"",
    "open:pillmate": "node scripts/open-simple-browser.mjs \"https://newon.app/ko/#pillmate-app\"",
    "open:ox-month": "node scripts/open-simple-browser.mjs /ko/#ox-month",
    "open:subping": "node scripts/open-simple-browser.mjs /ko/#subping-app",
    "open:newon-plus": "node scripts/open-simple-browser.mjs /ko/#newon-plus-app",
    "pack:upload": "node scripts/prepare-manual-upload.mjs",
    "묶기": "node scripts/prepare-manual-upload.mjs",
    "pack:pages": "node scripts/zip-publish.mjs",
    "ship": "node scripts/publish-site.mjs && bash scripts/push-to-github.sh",
    "push:first": "bash first-time-push.sh"
  },
  "devDependencies": {
    "@vitalets/google-translate-api": "^9.2.1"
  }
}
