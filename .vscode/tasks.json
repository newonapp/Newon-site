{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GitHub에 올리기 (add → commit → push)",
      "type": "shell",
      "command": "git add -A && (git diff --cached --quiet || git commit -m \"Site update\") && git push origin main",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": false
      }
    },
    {
      "label": "newon-publish",
      "type": "shell",
      "command": "node scripts/publish-site.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "newon-serve",
      "type": "shell",
      "command": "node scripts/serve-publish.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "newon-serve",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "미리보기: http://127\\.0\\.0\\.1:\\d+/"
        }
      }
    },
    {
      "label": "newon-open-simple-browser",
      "type": "shell",
      "command": "node scripts/open-simple-browser.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Cursor: Simple Browser로 /ko/ 열기 (서버 실행 중)",
      "type": "shell",
      "command": "node scripts/open-simple-browser.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Newon: Cursor에서 미리보기 (Simple Browser)",
      "dependsOn": ["newon-publish", "newon-serve", "newon-open-simple-browser"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
